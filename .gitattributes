# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf
# Force binary for these (never touch line endings)
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 filter=lfs diff=lfs merge=lfs -text
*.ttf filter=lfs diff=lfs merge=lfs -text
*.otf filter=lfs diff=lfs merge=lfs -text
